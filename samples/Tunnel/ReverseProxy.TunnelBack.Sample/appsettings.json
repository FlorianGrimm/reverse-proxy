{
  "Urls": "https://localhost:5002/",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Tunnel": {
    "Url": "https://localhost:5003/connect-h2?host=backend1.app"
  },
  "ReverseProxy": {
    "Tunnels": {
      "tunnel1": {
        "Url": "https://localhost:5003",
        "Url2": "https://localhost:5003/connect-h2?host=backend1.app",
        "Transport": "HTTP2",
        "Authentication": {}
      }
    },
    "Routes": {
      "route1": {
        "ClusterId": "cluster1",
        "Match": {
          "Path": "{**catch-all}"
        }
      }
    },
    "Clusters": {
      "cluster1": {
        "Destinations": {
          "cluster1/destination1": {
            "Address": "https://localhost:5001/"            
          }
        }
      }
    }
  }
}
