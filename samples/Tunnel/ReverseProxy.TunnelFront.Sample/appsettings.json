{
  "Urls": "https://localhost:5003/",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "TunnelFrontends": {
      "tunnel1": {
        "Listen": "tunnels://tunnel1",
        "Transport": "HTTP2",
        "Authentication": {}
      },
      "tunnel2": {
        "Listen": "tunnels://tunnel2",
        "Transport": "HTTP2",
        "Authentication": {}
      }
    },
    "Routes": {
      "route1": {
        "ClusterId": "alpha",
        "Match": {
          "Path": "{**catch-all}"
        }
      },
      "route2": {
        "ClusterId": "beta",
        "Match": {
          "Path": "/example"
        }
      }
    },
    "Clusters": {
      "alpha": {
        "Destinations": {
          "alpha/destination1": {
            "Address": "tunnels://tunnel1"
          },
          "alpha/destination2": {
            "Address": "tunnels://tunnel2"
          }

        },
        "Metadata": {
          "Transport": "Tunnel"
        }
      },
      "beta": {
        "Destinations": {
          "beta/destination1": {
            "Address": "https://example.com/"
          }
        }
      }
    }
  }
}
