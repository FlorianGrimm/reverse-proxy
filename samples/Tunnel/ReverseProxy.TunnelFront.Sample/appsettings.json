{
  "Urls": "https://localhost:5003/",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "TunnelFrontendToBackends": {
      "alpha": {
        "Transport": "TunnelHTTP2",
        "Authentication": {}
      },
      "beta": {
        "Transport": "TunnelHTTP2",
        "Authentication": {}
      }
    },
    "Routes": {
      "route1": {
        "ClusterId": "alpha",
        "Match": {
          "Path": "{**catch-all}"
        }
      },
      "route2": {
        "ClusterId": "beta",
        "Match": {
          "Path": "/beta/{**catch-all}"
        }
      },
      "route3": {
        "ClusterId": "gamma",
        "Match": {
          "Path": "/example"
        }
      }
    },
    "Clusters": {
      "alphaWeg": {
        "Destinations": {
          "alpha": {
            "Address": "https://localhost:5002"
          }
        }
      },
      "betaWeg": {
        "Destinations": {
          "beta": {
            "Address": "https://localhost:5002"
          }
        }
      },
      "gamma": {
        "Destinations": {
          "beta/destination1": {
            "Address": "https://example.com/"
          }
        }
      }
    }
  }
}
