{
  "Urls": "https://localhost:5003/",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Tunnels": {
      "tunnel1": {
        "Path": "/Tunnel/HTTP2/tunnel1",
        "Transport": "HTTP2",
        "Authentication": {}
      },
      "tunnel2": {
        "Path": "/Tunnel/WebSockets/tunnel2",
        "Transport": "WebSockets",
        "Authentication": {}
      }
    },
    "Routes": {
      "route1": {
        "ClusterId": "alpha",
        "Match": {
          "Path": "{**catch-all}"
        }
      },
      "route2": {
        "ClusterId": "beta",
        "Match": {
          "Path": "/example"
        }
      }
    },
    "Clusters": {
      "alpha": {
        "Destinations": {
          "alpha/destination1": {
            "Address": "https://tunnel1/",
            "Address2": "https://localhost:5001/",
            "Metadata": {
              "TunnelId": "tunnel1"
            }
          },
          "alpha/destination2": {
            "Address": "https://tunnel2/",
            "Address2": "https://localhost:5001/",
            "Metadata": {
              "TunnelId": "tunnel2"
            }
          }

        },
        "Metadata": {
          "Transport": "Tunnel"
        }
      },
      "beta": {
        "Destinations": {
          "beta/destination1": {
            "Address": "https://example.com/"
          }
        }
      }
    }
  }
}
