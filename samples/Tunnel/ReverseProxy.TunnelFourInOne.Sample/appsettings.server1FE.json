{
  "Urls": "https://localhost:5001/",
  "Comment": "The tunnel front end",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "TunnelFrontendToBackends": {
      "alpha": {
        "Transport": "HTTP2",
        "Authentication": {}
      },
      "beta": {
        "Transport": "HTTP2",
        "Authentication": {}
      }
    },
    "Routes": {
      "route1": {
        "ClusterId": "alpha",
        "Match": {
          "Path": "{**catch-all}"
        }
      },
      "route2": {
        "ClusterId": "beta",
        "Match": {
          "Path": "/beta/{**catch-all}"
        }
      },
      "route3": {
        "ClusterId": "gamma",
        "Match": {
          "Path": "/example"
        }
      }
    },
    "Clusters": {
      "alpha": {
        "Destinations": {
          "alpha/destination1": {
            "Address": "tunnel://alpha"
          }
        },
        "Transport": "Tunnel"
      },
      "beta": {
        "Destinations": {
          "beta/destination1": {
            "Address": "https://localhost:5004"
          }
        },
        "Transport": "Tunnel"
      },
      "gamma": {
        "Destinations": {
          "beta/destination1": {
            "Address": "https://example.com/"
          }
        },
        "Transport": "HTTP"
      }
    }
  }
}
