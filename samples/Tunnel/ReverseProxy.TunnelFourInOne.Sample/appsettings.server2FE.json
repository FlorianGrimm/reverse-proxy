{
  "Urls": "https://localhost:5002/",
  "Comment": "The tunnel front end",
  "AllowedHosts": "*",
  "ReverseProxy": {
    "TunnelFrontendToBackends": {
      "alpha": {
        "Transport": "TunnelHTTP2",
        "Authentication": {}
      },
      "beta": {
        "Transport": "TunnelHTTP2",
        "Authentication": {}
      }
    },
    "Routes": {
      "route1": {
        "ClusterId": "alpha",
        "Match": {
          "Path": "{**catch-all}"
        }
      },
      "route2": {
        "ClusterId": "beta",
        "Match": {
          "Path": "/beta/{**catch-all}"
        }
      },
      "route3": {
        "ClusterId": "gamma",
        "Match": {
          "Path": "/example"
        }
      }
    },
    "Clusters": {
      "gamma": {
        "Destinations": {
          "beta/destination1": {
            "Address": "https://example.com/"
          }
        },
        "CommentTransport": "HTTP"
      }
    }
  }
}
