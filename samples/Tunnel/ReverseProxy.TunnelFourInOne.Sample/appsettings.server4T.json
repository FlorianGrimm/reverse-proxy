{
  "Urls": "https://localhost:5004/",
  "Comment": "The tunnel backend",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Tunnel": {
    "Url": "https://localhost:5001/connect-h2?host=backend1.app"
  },
  "ReverseProxy": {
    "TunnelBackendToFrontends": {
      "tunnelA": {
        "Url": "https://localhost:5001",
        "Url2": "https://localhost:5001/connect-h2?host=backend1.app",
        "RemoteTunnelId": "tunnel1",
        "Transport": "TunnelHTTP2",
        "Authentication": {}
      },
      "tunnelB": {
        "Url": "https://localhost:5002",
        "Url2": "https://localhost:5001/connect-h2?host=backend1.app",
        "RemoteTunnelId": "tunnel1",
        "Transport": "TunnelHTTP2",
        "Authentication": {}
      }
    },
    "Routes": {
      "route1": {
        "ClusterId": "alpha",
        "Match": {
          "Path": "{**catch-all}"
        }
      },
      "route2": {
        "ClusterId": "beta",
        "Match": {
          "Path": "/beta/{**catch-all}"
        }
      },
      "route3": {
        "ClusterId": "gamma",
        "Match": {
          "Path": "/example"
        }
      }
    },
    "Clusters": {
      "alphaWeg": {
        "Destinations": {
          "alpha": {
            "Address": "https://localhost:5003"
          }
        }
      },
      "betaWeg": {
        "Destinations": {
          "beta": {
            "Address": "https://localhost:5004"
          }
        }
      },
      "gamma": {
        "Destinations": {
          "gamma/destination1": {
            "Address": "https://example.com/"
          }
        }
      }
    }
  }
}
